@model LibraryApp.Models.BorrowingConfig

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>BorrowingConfig</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="LoanDurationDays" class="control-label"></label>
                <input asp-for="LoanDurationDays" class="form-control" />
                <span asp-validation-for="LoanDurationDays" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MaxRenewals" class="control-label"></label>
                <input asp-for="MaxRenewals" class="form-control" />
                <span asp-validation-for="MaxRenewals" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MaxItemsPerMember" class="control-label"></label>
                <input asp-for="MaxItemsPerMember" class="form-control" />
                <span asp-validation-for="MaxItemsPerMember" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DailyPenalty" class="control-label"></label>
                <input asp-for="DailyPenalty" class="form-control" />
                <span asp-validation-for="DailyPenalty" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MaxPenaltyCap" class="control-label"></label>
                <input asp-for="MaxPenaltyCap" class="form-control" />
                <span asp-validation-for="MaxPenaltyCap" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="GracePeriodDays" class="control-label"></label>
                <input asp-for="GracePeriodDays" class="form-control" />
                <span asp-validation-for="GracePeriodDays" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="AllowRenewals" /> @Html.DisplayNameFor(model => model.AllowRenewals)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="AllowReservations" /> @Html.DisplayNameFor(model => model.AllowReservations)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
