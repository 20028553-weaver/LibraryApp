@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Welcome to LibraryApp</h2>

<div class="row g-3">
    <div class="col-md-4">
        <a href="/Books" class="text-decoration-none">
            <div class="card text-center p-3 h-100">
                <i class="bi bi-journal-bookmark fs-1 text-primary"></i>
                <h5 class="mt-2">Books</h5>
                <p class="text-muted small">Browse the catalogue</p>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Members" class="text-decoration-none">
            <div class="card text-center p-3 h-100">
                <i class="bi bi-people fs-1 text-success"></i>
                <h5 class="mt-2">Members</h5>
                <p class="text-muted small">Manage members</p>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/BorrowTransactions/IssueBook" class="text-decoration-none">
            <div class="card text-center p-3 h-100">
                <i class="bi bi-plus-circle fs-1 text-warning"></i>
                <h5 class="mt-2">Issue Book</h5>
                <p class="text-muted small">New borrowing</p>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/BorrowTransactions/Overdue" class="text-decoration-none">
            <div class="card text-center p-3 h-100">
                <i class="bi bi-clock-history fs-1 text-danger"></i>
                <h5 class="mt-2">Overdue</h5>
                <p class="text-muted small">Past due books</p>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Reservations" class="text-decoration-none">
            <div class="card text-center p-3 h-100">
                <i class="bi bi-bookmark fs-1 text-info"></i>
                <h5 class="mt-2">Reservations</h5>
                <p class="text-muted small">Book holds</p>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Penalties" class="text-decoration-none">
            <div class="card text-center p-3 h-100">
                <i class="bi bi-exclamation-triangle fs-1 text-danger"></i>
                <h5 class="mt-2">Penalties</h5>
                <p class="text-muted small">Outstanding fines</p>
            </div>
        </a>
    </div>
</div>