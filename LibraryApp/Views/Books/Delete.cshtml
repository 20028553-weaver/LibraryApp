@model LibraryApp.Models.Book
@{
    ViewData["Title"] = "Delete Book";
}

<h2 class="text-danger mb-4">Delete Book</h2>
<div class="card p-4" style="max-width:500px;">
    <p>Are you sure you want to delete <strong>"@Model.Title"</strong> by @Model.Author?</p>
    <form method="post" action="/Books/Delete/@Model.Id">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a href="/Books" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>