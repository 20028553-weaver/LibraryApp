@model LibraryApp.Models.Book
@{
    ViewData["Title"] = "Edit Book";
}

<h2 class="mb-4">Edit: @Model.Title</h2>
<div class="card p-4" style="max-width:600px;">
    <form method="post" action="/Books/Edit/@Model.Id">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label asp-for="Title" class="form-label">Title *</label>
            <input asp-for="Title" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Author" class="form-label">Author *</label>
            <input asp-for="Author" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="ISBN" class="form-label">ISBN *</label>
            <input asp-for="ISBN" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Publisher" class="form-label">Publisher</label>
            <input asp-for="Publisher" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="YearPublished" class="form-label">Year</label>
            <input asp-for="YearPublished" type="number" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="TotalCopies" class="form-label">Total Copies</label>
            <input asp-for="TotalCopies" type="number" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="AvailableCopies" class="form-label">Available Copies</label>
            <input asp-for="AvailableCopies" type="number" class="form-control" />
        </div>
        <div class="mb-3 form-check">
            <input asp-for="IsAvailable" type="checkbox" class="form-check-input" />
            <label asp-for="IsAvailable" class="form-check-label">Is Available</label>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/Books/Details/@Model.Id" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>