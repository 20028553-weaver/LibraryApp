@model IEnumerable<LibraryApp.Models.Book>
@{
    ViewData["Title"] = "Books";
    string search = Context.Request.Query["search"].ToString();
    var list = string.IsNullOrEmpty(search) ? Model
        : Model.Where(b => b.Title.Contains(search, StringComparison.OrdinalIgnoreCase)
                        || b.Author.Contains(search, StringComparison.OrdinalIgnoreCase));
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Books (@Model.Count())</h2>
    <a href="/Books/Create" class="btn btn-primary">Add Book</a>
</div>

<form method="get" class="mb-3 d-flex gap-2">
    <input class="form-control" name="search" placeholder="Search title or author…"
           value="@search" style="max-width:300px;" />
    <button type="submit" class="btn btn-outline-secondary">Search</button>
    @if (!string.IsNullOrEmpty(search))
    {
        <a href="/Books" class="btn btn-outline-danger">Clear</a>
    }
</form>

@if (!list.Any())
{
    <div class="alert alert-info">No books found.</div>
}
else
{
    <table class="table table-bordered table-hover bg-white">
        <thead class="table-dark">
            <tr><th>Title</th><th>Author</th><th>ISBN</th><th>Copies</th><th>Status</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var b in list)
            {
                <tr>
                    <td>@b.Title</td>
                    <td>@b.Author</td>
                    <td>@b.ISBN</td>
                    <td>@b.AvailableCopies / @b.TotalCopies</td>
                    <td>
                        @if (b.IsAvailable && b.AvailableCopies > 0)
                        {
                            <span class="badge bg-success">Available</span>
                        }
                        else
                        {

                            <span class="badge bg-danger">Out</span>
                        }
                    </td>
                    <td>
                        <a href="/Books/Details/@b.Id" class="btn btn-sm btn-outline-secondary">View</a>
                        <a href="/Books/Edit/@b.Id" class="btn btn-sm btn-outline-primary ms-1">Edit</a>
                        <a href="/Books/Delete/@b.Id" class="btn btn-sm btn-outline-danger ms-1">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}