@model IEnumerable<LibraryApp.Models.Member>
@{
    ViewData["Title"] = "Members";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Members (@Model.Count())</h2>
    <a href="/Members/Create" class="btn btn-primary">Add Member</a>
</div>

<table class="table table-bordered table-hover bg-white">
    <thead class="table-dark">
        <tr><th>#</th><th>Name</th><th>Email</th><th>Phone</th><th>Status</th><th>Actions</th></tr>
    </thead>
    <tbody>
        @foreach (var m in Model.OrderBy(x => x.FullName))
        {
            <tr>
                <td>@m.Id</td>
                <td>@m.FullName</td>
                <td>@m.Email</td>
                <td>@(m.Phone ?? "—")</td>
                <td>
                    @if (m.Status == "Active")
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {

                        <span class="badge bg-secondary">@m.Status</span>
                    }
                </td>
                <td>
                    <a href="/Members/Details/@m.Id" class="btn btn-sm btn-outline-secondary">View</a>
                    <a href="/Members/Edit/@m.Id" class="btn btn-sm btn-outline-primary ms-1">Edit</a>
                    <a href="/Members/Delete/@m.Id" class="btn btn-sm btn-outline-danger ms-1">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>