@model IEnumerable<LibraryApp.Models.Member>
@{
    ViewData["Title"] = "Members";
}

<div class="page-header">
    <h2><i class="bi bi-people me-2"></i>Members <span class="text-muted fw-normal fs-6">(@Model.Count())</span></h2>
    <a href="/Members/Create" class="btn btn-nepal-red">
        <i class="bi bi-person-plus me-1"></i> Add Member
    </a>
</div>

<div class="bg-white rounded shadow-sm">
    <table class="table table-hover mb-0 lib-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Membership Expiry</th>
                <th>Active Borrows</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Model)
            {
                var activeBorrows = m.BorrowTransactions.Count(bt => bt.Status == "Borrowed" && bt.ReturnDate == null);
                <tr>
                    <td class="text-muted small">@m.Id</td>
                    <td class="fw-semibold">@m.FullName</td>
                    <td class="small">@m.Email</td>
                    <td class="small">@(m.Phone ?? "—")</td>
                    <td class="small @(m.MembershipExpiry.HasValue && m.MembershipExpiry < DateTime.Today ? "text-danger" : "")">
                        @(m.MembershipExpiry?.ToString("dd MMM yyyy") ?? "—")
                    </td>
                    <td>
                        @if (activeBorrows > 0)
                        {
                            <span class="badge badge-borrowed">@activeBorrows</span>
                        }
                        else
                        {
                            <span class="text-muted small">0</span>
                        }
                    </td>
                    <td>
                        @if (m.Status == "Active")
                        {
                            <span class="badge badge-active">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-inactive">@m.Status</span>
                        }
                    </td>
                    <td>
                        <a href="/Members/Details/@m.Id" class="btn btn-sm btn-outline-secondary me-1">View</a>
                        <a href="/Members/Edit/@m.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                        <a href="/Members/Delete/@m.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">No members found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
