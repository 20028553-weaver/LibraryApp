@model LibraryApp.Models.Member
@{
    ViewData["Title"] = "Delete Member";
}

<h2 class="text-danger mb-4">Delete Member</h2>
<div class="card p-4" style="max-width:500px;">
    <p>Are you sure you want to delete <strong>@Model.FullName</strong>?</p>
    <p class="text-muted">@Model.Email</p>
    <form method="post" action="/Members/Delete/@Model.Id">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a href="/Members" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>