@model LibraryApp.Models.Penalty
@{
    ViewData["Title"] = "Edit Penalty";
}

<h2 class="mb-4">Edit Penalty #@Model.Id</h2>
<div class="card p-4" style="max-width:500px;">
    <form method="post" action="/Penalties/Edit/@Model.Id">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label asp-for="MemberId" class="form-label">Member</label>
            <select asp-for="MemberId" asp-items="ViewBag.MemberId" class="form-select"></select>
        </div>
        <div class="mb-3">
            <label asp-for="BorrowTransactionId" class="form-label">Transaction</label>
            <select asp-for="BorrowTransactionId" asp-items="ViewBag.BorrowTransactionId" class="form-select"></select>
        </div>
        <div class="mb-3">
            <label asp-for="Amount" class="form-label">Amount ($)</label>
            <input asp-for="Amount" type="number" step="0.01" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Status" class="form-label">Status</label>
            <select asp-for="Status" class="form-select">
                <option value="Unpaid">Unpaid</option>
                <option value="Paid">Paid</option>
            </select>
        </div>
        <div class="mb-3">
            <label asp-for="DatePaid" class="form-label">Date Paid</label>
            <input asp-for="DatePaid" type="datetime-local" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/Penalties" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>