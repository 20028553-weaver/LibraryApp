@model IEnumerable<LibraryApp.Models.Penalty>
@{
    ViewData["Title"] = "Penalties";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Penalties</h2>
    <form method="post" action="/Penalties/GenerateAll">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-warning" onclick="return confirm('Generate penalties for all overdue books?')">
            Generate All Penalties
        </button>
    </form>
</div>

@if (!Model.Any())
{
    <div class="alert alert-success">No penalties on record.</div>
}
else
{
    <table class="table table-bordered table-hover bg-white">
        <thead class="table-dark">
            <tr><th>#</th><th>Member</th><th>Book</th><th>Amount</th><th>Date Issued</th><th>Status</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Member?.FullName</td>
                    <td>@p.BorrowTransaction?.Book?.Title</td>
                    <td class="@(p.Status == "Paid" ? "text-success" : "text-danger") fw-bold">
                        $@p.Amount.ToString("F2")
                    </td>
                    <td>@p.DateIssued.ToString("dd MMM yyyy")</td>
                    <td>
                        @if (p.Status == "Paid")
                        {
                            <span class="badge bg-success">Paid</span>
                        }
                        else
                        {

                            <span class="badge bg-danger">Unpaid</span>
                        }
                    </td>
                    <td>
                        @if (p.Status != "Paid")
                        {
                            <form method="post" action="/Penalties/MarkPaid/@p.Id" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Mark as paid?')">Mark Paid</button>
                            </form>
                        }
                        <a href="/Penalties/Edit/@p.Id" class="btn btn-sm btn-outline-secondary ms-1">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}