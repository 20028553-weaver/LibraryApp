@model LibraryApp.Models.BorrowTransaction
@{
    ViewData["Title"] = "Edit Transaction";
}

<h2 class="mb-4">Edit Transaction #@Model.Id</h2>
<div class="card p-4" style="max-width:600px;">
    <form method="post" action="/BorrowTransactions/Edit/@Model.Id">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label asp-for="BookId" class="form-label">Book</label>
            <select asp-for="BookId" asp-items="ViewBag.BookId" class="form-select"></select>
        </div>
        <div class="mb-3">
            <label asp-for="MemberId" class="form-label">Member</label>
            <select asp-for="MemberId" asp-items="ViewBag.MemberId" class="form-select"></select>
        </div>
        <div class="mb-3">
            <label asp-for="Status" class="form-label">Status</label>
            <select asp-for="Status" class="form-select">
                <option>Borrowed</option>
                <option>Returned</option>
            </select>
        </div>
        <div class="mb-3">
            <label asp-for="DueDate" class="form-label">Due Date</label>
            <input asp-for="DueDate" type="datetime-local" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="ReturnDate" class="form-label">Return Date</label>
            <input asp-for="ReturnDate" type="datetime-local" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="RenewCount" class="form-label">Renew Count</label>
            <input asp-for="RenewCount" type="number" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/BorrowTransactions" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>