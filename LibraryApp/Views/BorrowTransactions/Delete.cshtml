@model LibraryApp.Models.BorrowTransaction
@{
    ViewData["Title"] = "Delete Transaction";
}

<h2 class="text-danger mb-4">Delete Transaction</h2>
<div class="card p-4" style="max-width:500px;">
    <p>Are you sure you want to delete transaction <strong>#@Model.Id</strong>?</p>
    <p><strong>Book:</strong> @Model.Book?.Title</p>
    <p><strong>Member:</strong> @Model.Member?.FullName</p>
    <form method="post" action="/BorrowTransactions/Delete/@Model.Id">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a href="/BorrowTransactions" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>