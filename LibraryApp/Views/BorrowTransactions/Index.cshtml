@model IEnumerable<LibraryApp.Models.BorrowTransaction>
@{
    ViewData["Title"] = "Transactions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Borrow Transactions</h2>
    <a href="/BorrowTransactions/Borrow" class="btn btn-primary"><i class="bi bi-plus"></i> Issue Book</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No transactions yet.</div>
}
else
{
    <table class="table table-bordered table-hover bg-white">
        <thead class="table-dark">
            <tr><th>#</th><th>Book</th><th>Member</th><th>Borrow Date</th><th>Due Date</th><th>Status</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var t in Model.OrderByDescending(x => x.BorrowDate))
            {
                bool overdue = t.ReturnDate == null && t.DueDate < DateTime.Now && t.Status == "Borrowed";
                <tr class="@(overdue ? "table-danger" : "")">
                    <td>@t.Id</td>
                    <td>@t.Book?.Title</td>
                    <td>@t.Member?.FullName</td>
                    <td>@t.BorrowDate.ToString("dd MMM yyyy")</td>
                    <td>@t.DueDate.ToString("dd MMM yyyy")</td>
                    <td>
                        @if (overdue)
                        {
                            <span class="badge bg-danger">Overdue</span>
                        }
                        else if (t.Status == "Borrowed")
                        {

                            <span class="badge bg-warning text-dark">Borrowed</span>
                        }
                        else
                        {

                            <span class="badge bg-success">Returned</span>
                        }
                    </td>
                    <td>
                        <a href="/BorrowTransactions/Details/@t.Id" class="btn btn-sm btn-outline-secondary">View</a>
                        @if (t.ReturnDate == null && t.Status == "Borrowed")
                        {
                            <form method="post" action="/BorrowTransactions/Return/@t.Id" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success ms-1" onclick="return confirm('Return this book?')">Return</button>
                            </form>
                            <form method="post" action="/BorrowTransactions/Renew/@t.Id" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-primary ms-1" onclick="return confirm('Renew?')">Renew</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}