@model IEnumerable<LibraryApp.Models.Reservation>
@{
    ViewData["Title"] = "Reservations";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Reservations</h2>
    <a href="/Reservations/Reserve" class="btn btn-primary">New Reservation</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No reservations yet.</div>
}
else
{
    <table class="table table-bordered table-hover bg-white">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Book</th>
                <th>Member</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Id</td>
                    <td>@r.Book?.Title</td>
                    <td>@r.Member?.FullName</td>
                    <td>
                        @if (r.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                        else if (r.Status == "Fulfilled")
                        {
                            <span class="badge bg-success">Fulfilled</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@r.Status</span>
                        }
                    </td>
                    <td>
                        @if (r.Status == "Pending")
                        {
                            <form method="post"
                                  action="/Reservations/Fulfil/@r.Id"
                                  style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm btn-success"
                                        onclick="return confirm('Fulfil?')">
                                    Fulfil
                                </button>
                            </form>
                            <form method="post"
                                  action="/Reservations/Cancel/@r.Id"
                                  style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm btn-danger ms-1"
                                        onclick="return confirm('Cancel?')">
                                    Cancel
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}